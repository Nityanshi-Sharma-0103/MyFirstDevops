# digital_clock_terminal.py
import sys
import time
from datetime import datetime

try:
    while True:
        now = datetime.now()
        sys.stdout.write("\r" + now.strftime("%Y-%m-%d  %H:%M:%S"))
        sys.stdout.flush()
        # sleep exactly until the next second
        time.sleep(1 - now.microsecond / 1_000_000)
except KeyboardInterrupt:
    pass  # exit cleanly on Ctrl+C
